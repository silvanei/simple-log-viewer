{
  "name": "s3/simple-log-viewer",
  "version": "0.0.1",
  "description": "Simple log viewer for development environment",
  "authors": [
    {
      "name": "Silvanei Soares Santos",
      "email": "ads.silvanei@gmail.com"
    }
  ],
  "minimum-stability": "stable",
  "autoload": {
    "psr-4": {
      "S3\\Log\\Viewer\\": "src/"
    },
    "files": [
      "config/php/env.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Test\\S3\\Log\\Viewer\\": "test/src/",
      "Test\\Support\\S3\\Log\\Viewer\\": "test/support/"
    }
  },
  "require": {
    "php": ">=8.5",
    "ext-pdo": "*",
    "psr/http-message": "^2.0",
    "psr/http-server-handler": "^1.0",
    "psr/http-server-middleware": "^1.0",
    "nikic/fast-route": "^1.3",
    "respect/validation": "^2.4",
    "nyholm/psr7": "^1.8",
    "nyholm/psr7-server": "^1.1"
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "^4.0",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^12.5",
    "infection/infection": "^0.31.9"
  },
  "scripts": {
    "check": [
      "@test",
      "@phpstan",
      "@phpcs"
    ],
    "phpcs": "phpcs --standard=config/php/phpcs.xml",
    "phpstan": "phpstan analyse -c config/php/phpstan.neon --memory-limit=-1",
    "test": "phpunit --configuration config/php/phpunit.xml",
    "test-coverage": "XDEBUG_MODE=coverage phpunit --configuration config/php/phpunit.xml --coverage-html storage/coverage/",
    "test-infection": "vendor/bin/infection --configuration=config/php/infection.json"
  },
  "config": {
    "allow-plugins": {
      "infection/extension-installer": true
    }
  }
}
